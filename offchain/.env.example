# Blockfrost Preview Testnet API Key
# Get your key at https://blockfrost.io
BLOCKFROST_API_KEY=previewYOUR_KEY_HERE

# Alice (Borrower) wallet — 24-word mnemonic, space-separated
ALICE_MNEMONIC=word1 word2 word3 ... word24

# Bob (Lender) wallet — 24-word mnemonic, space-separated
BOB_MNEMONIC=word1 word2 word3 ... word24

# Collateral NFT — fill after running: npm run mint-nft
NFT_POLICY_ID=
NFT_ASSET_NAME=CollateralNFT

# Loan UTxO hash — fill from test-create.ts output
# LOAN_TX_HASH=
